# Server
APP_ENV=development
SERVER_PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=pitch_user
DB_PASSWORD=strongpassword
DB_NAME=pitch_booking_db
DB_MAX_CONNS=20
DB_MIN_CONNS=5

# Auth / JWT (required)
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h
BCRYPT_COST=12

# OTP (phone-first auth)
# Server-side HMAC pepper keying the stored one-time-code digests. Required,
# minimum 16 chars. NEVER reuse JWT_SECRET — generate an independent secret.
OTP_HMAC_PEPPER=change-me-to-an-independent-random-secret

# Notification delivery channel: FAKE | SMS | WHATSAPP (defaults to FAKE)
NOTIFICATION_CHANNEL=FAKE

# ── Notification routing (MVP auth channel) ────────────────────────────────────
# Type → sink routing policy, resolved at send time. Defaults encode the closed-
# beta policy: OTP over Twilio SMS, booking events to a non-delivering log sink.
# Registered sink names: twilio_sms | log_only | FAKE | SMS | WHATSAPP.
#
# ⚠️ LOCAL DEV DX: the default OTP route is `twilio_sms`, so a machine WITHOUT
# Twilio credentials will FAIL BOOT by design (the safety assertion refuses to let
# OTP resolve to no real sender — a silent OTP→log route is a login outage).
# For local development without Twilio, route OTP to the console Fake adapter:
#
#     NOTIFY_OTP_ROUTE=FAKE
#
# Then request an OTP from the login page and read the code from the backend
# console line `[NOTIFY:FAKE] >>> OTP for +962... is 123456 <<<`.
NOTIFY_OTP_ROUTE=FAKE
# Booking-event sink and the fail-safe default for any unmapped message kind.
NOTIFY_BOOKING_ROUTE=log_only
NOTIFY_DEFAULT_ROUTE=log_only

# ── Twilio Programmable SMS (closed-beta OTP delivery) ─────────────────────────
# Required only when an OTP/route resolves to twilio_sms (e.g. the closed beta).
# All three must be set together or boot fails fast. On a TRIAL account, SMS is
# delivered ONLY to numbers verified in the Twilio console, bodies are prefixed
# "Sent from a Twilio Trial account", and a daily ceiling applies (error 63038).
# NEVER commit a real auth token — it lives in the environment only.
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_FROM_NUMBER=+15005550006

# Platform-wide OTP send ceiling per rolling day (Tier-0 anti-AIT circuit breaker).
# Aligned with the ~50/day Twilio trial limit so the closed beta cannot exceed it.
OTP_GLOBAL_DAILY_CAP=50

# WhatsApp (Meta Cloud API) — PART 4.
# Required only when NOTIFICATION_CHANNEL=WHATSAPP. Meta business verification is
# pending, so these are DUMMY placeholders; the adapter falls back to SMS on any
# Cloud API failure (e.g. an unapproved AUTHENTICATION/OTP template).
# NEVER commit real tokens — these live in the environment only.
WHATSAPP_TOKEN=dummy-meta-cloud-api-token
WHATSAPP_PHONE_ID=000000000000000
# Endpoint coordinates (sane defaults shown; override only if needed)
WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v21.0
# Approved template names, one per message kind, and their BCP-47 language code
WHATSAPP_TEMPLATE_LANG=en
WHATSAPP_OTP_TEMPLATE=malaeb_otp
WHATSAPP_BOOKING_CONFIRMED_TEMPLATE=malaeb_booking_confirmed
WHATSAPP_BOOKING_CANCELLED_TEMPLATE=malaeb_booking_cancelled