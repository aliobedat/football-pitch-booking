# Server
APP_ENV=development
SERVER_PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=pitch_user
DB_PASSWORD=strongpassword
DB_NAME=pitch_booking_db
DB_MAX_CONNS=20
DB_MIN_CONNS=5

# Auth / JWT (required)
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h
BCRYPT_COST=12

# OTP (phone-first auth)
# Server-side HMAC pepper keying the stored one-time-code digests. Required,
# minimum 16 chars. NEVER reuse JWT_SECRET — generate an independent secret.
OTP_HMAC_PEPPER=change-me-to-an-independent-random-secret

# Notification delivery channel: FAKE | SMS | WHATSAPP (defaults to FAKE)
NOTIFICATION_CHANNEL=FAKE

# WhatsApp (Meta Cloud API) — PART 4.
# Required only when NOTIFICATION_CHANNEL=WHATSAPP. Meta business verification is
# pending, so these are DUMMY placeholders; the adapter falls back to SMS on any
# Cloud API failure (e.g. an unapproved AUTHENTICATION/OTP template).
# NEVER commit real tokens — these live in the environment only.
WHATSAPP_TOKEN=dummy-meta-cloud-api-token
WHATSAPP_PHONE_ID=000000000000000
# Endpoint coordinates (sane defaults shown; override only if needed)
WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v21.0
# Approved template names, one per message kind, and their BCP-47 language code
WHATSAPP_TEMPLATE_LANG=en
WHATSAPP_OTP_TEMPLATE=malaeb_otp
WHATSAPP_BOOKING_CONFIRMED_TEMPLATE=malaeb_booking_confirmed
WHATSAPP_BOOKING_CANCELLED_TEMPLATE=malaeb_booking_cancelled