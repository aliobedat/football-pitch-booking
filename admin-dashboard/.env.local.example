# Backend API origin (same backend as the player app).
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Where players (non-dashboard roles) are bounced to.
NEXT_PUBLIC_B2C_URL=http://localhost:3000

# httpOnly access-cookie name the edge middleware reads role from (UX only).
NEXT_PUBLIC_ACCESS_COOKIE=malaab_access
